{
  "manifest_version": 3,
  "name": "Flash Dash",
  "version": "1.0",
  "description": "Beautiful new tab with a big clock, Google search, goal photos, tasks, and bookmarks. Everything you need, nothing you don't.",
  "chrome_url_overrides": {
  "newtab": "newtab.html"
}
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks",
    "tabs"
  ],
  "host_permissions": [
    "https://suggestqueries.google.com/"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
